{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true
    },
    "references": [
        {
            "path": "./tsconfig.main.json"
        },
        {
            "path": "./tsconfig.preload.json"
        },
        {
            "path": "./tsconfig.renderer.json"
        }
    ]
}