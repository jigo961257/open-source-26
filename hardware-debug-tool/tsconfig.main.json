{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "outDir": "dist/main",
        "rootDir": "src/main",
        "types": [
            "node"
        ]
    },
    "include": [
        "src/main/**/*"
    ]
}